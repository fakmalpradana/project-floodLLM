# ═══════════════════════════════════════════════════════════════════════
# FloodLLM — Environment Variable Reference
# Copy this file to .env and fill in your values.
# .env is in .gitignore and is NEVER committed.
# ═══════════════════════════════════════════════════════════════════════

# ── Google AI (Gemini) ───────────────────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_key

# ── Copernicus Data Space (Sentinel-1/2 data) ────────────────────────
COPERNICUS_USERNAME=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# ── NASA Earthdata (GPM rainfall) ────────────────────────────────────
NASA_EARTHDATA_USERNAME=your_nasa_earthdata_username
NASA_EARTHDATA_PASSWORD=your_nasa_earthdata_password

# ── GCP Configuration ────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1
GCP_BUCKET_NAME=your-bucket-name
# Only needed for local Earth Engine access (not required on Cloud Run)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/local-service-account-key.json
GCP_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com

# ── Deployed Service URLs (auto-populated after first deploy) ─────────
BACKEND_URL=https://floodllm-backend-XXXXXX.asia-southeast1.run.app
FRONTEND_URL=https://floodllm-frontend-XXXXXX.asia-southeast1.run.app

# ── App Settings ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
